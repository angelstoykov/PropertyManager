@using PropertyManager.Domain.Models.Enums
@using PropertyManager.WEB.ViewModels.Properties
@model CreatePropertyViewModel

<h2>Create Property</h2>

<form asp-action="Create" method="post">

    <div class="form-group">
        <label>Property</label>
        <input asp-for="Name" class="form-control" />
    </div>

    <div class="form-group">
        <label>Address</label>
        <input asp-for="Address" class="form-control" />
    </div>

    <div class="form-group">
        <label>Owner</label>
        <input asp-for="Owner" class="form-control" />
    </div>

    <div class="form-group">
        <label>Type</label>
        <select asp-for="Type" class="form-control"
                asp-items="Html.GetEnumSelectList<PropertyType>()"></select>
    </div>

    <div class="form-group">
        <label>Status</label>
        <select asp-for="Status" class="form-control"
                asp-items="Html.GetEnumSelectList<PropertyStatus>()"></select>
    </div>

    <button type="submit" class="btn btn-primary mt-2">
        Create
    </button>

</form>
