@using PropertyManager.Domain.Models.Enums
@using PropertyManager.WEB.ViewModels.Clients

@model DeleteClientViewModel

<h2>Delete Client</h2>

<div class="card">
    <div class="card-body">
        <p><strong>Name:</strong> @Model.DisplayName</p>
        <p><strong>Type:</strong> @(Model.ClientType == ClientType.Individual ? "Individual" : "Legal entity")</p>
        <p class="text-danger mt-3">Are you sure you want to delete this client?</p>
    </div>
    <div class="card-footer">
        <form asp-action="DeleteConfirmed" method="post">
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-danger">Confirm Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
