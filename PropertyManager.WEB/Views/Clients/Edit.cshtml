@using PropertyManager.WEB.ViewModels.Clients
@model ClientFormViewModel

<h2>Edit Client</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <partial name="_ClientFormFields" model="Model" />

    <button type="submit" class="btn btn-primary mt-2">Save</button>
    <a asp-action="Index" class="btn btn-secondary mt-2">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/clients/client-form.js"></script>
}
