@using PropertyManager.Domain.Models.Enums
@using PropertyManager.WEB.ViewModels.Units

@model UnitIndexViewModel

@section Scripts {
    <script src="~/js/units/units-index.js"></script>
}

<h2>Units</h2>
<a asp-action="Create" asp-route-id="@Model.PropertyId" class="btn btn-sm btn-warning">Create</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Unit</th>
            <th>Building</th>
            <th>Floor</th>
            <th>Size</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var unit in Model.Units)
        {
            <tr>
                <td>@unit.UnitNumber</td>
                <td>@unit.PropertyName</td>
                <td>@unit.Floor</td>
                <td>@unit.Area</td>
                <td>@unit.Status</td>
                <td>
                    <a asp-action="Details" asp-route-id="@unit.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@unit.Id" class="btn btn-sm btn-warning">Edit</a>
                    <!-- TODO: This DELETE functionality should be different -->
                    <button class="btn btn-sm btn-danger js-delete-unit"
                            data-unit-id="@unit.Id"
                            data-unit-name="@unit.UnitNumber">
                        Delete
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-3">
    @for (int i = 1; i <= Model.TotalPages; i++)
    {
        <a asp-action="Index"
           asp-route-page="@i"
           asp-route-propertyId="@Model.PropertyId"
           asp-route-status="@Model.Status"
           class="btn btn-sm @(i == Model.Page ? "btn-primary" : "btn-light")">
            @i
        </a>
    }
</div>

@await Html.PartialAsync("_ConfirmDeleteModal")
